{
  "name": "bbn-ms/isp-management-system",
  "description": "Professional ISP Management System backend using PHP and MongoDB",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-mongodb": "*",
    "mongodb/mongodb": "^2.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "php -S localhost:8080 -t public"
    ],
    "db:clear": [
      "@php database/clear_data.php"
    ],
    "post-install-cmd": [
      "@php -r \"if (!file_exists('.env') && file_exists('.env.example')) copy('.env.example', '.env');\""
    ]
  }
}
